# =============================================================================
# WAZASH Backend - Variables d'environnement
# =============================================================================
# Copier ce fichier vers .env et ajuster les valeurs selon l'environnement
# =============================================================================

# --- Application ---
# Nom de l'application (affiché dans la documentation Swagger)
APP_NAME=WAZASH

# Mode debug (true/false) - Active les traces d'erreurs détaillées
# ATTENTION: Ne jamais mettre true en production
DEBUG=false

# --- API ---
# Préfixe pour toutes les routes de l'API v1
API_V1_PREFIX=/api/v1

# --- Configuration serveur (optionnel) ---
# HOST=0.0.0.0
# PORT=8000

# --- Base de données (réservé pour EPIC-02) ---
# DATABASE_URL=sqlite+aiosqlite:///./wazash.db

# --- Sécurité (réservé pour EPIC-03) ---
# SECRET_KEY=change-me-in-production
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
