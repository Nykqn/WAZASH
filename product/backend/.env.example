# =============================================================================
# WAZASH Backend - Variables d'environnement (EPIC-07)
# =============================================================================

# --- Application ---
APP_NAME=WAZASH
DEBUG=false
API_V1_PREFIX=/api/v1

# --- Base de données ---
# PostgreSQL (production/Docker)
DATABASE_URL=postgresql://wazash:wazash@db:5432/wazash
# SQLite (dev local sans Docker)
# DATABASE_URL=sqlite:///./wazash.db

# --- Sécurité ---
# Clé secrète pour JWT — CHANGER EN PRODUCTION
# Générer une clé : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORS ---
# Origines autorisées pour les requêtes CORS (séparées par des virgules)
# CORS_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080"]
